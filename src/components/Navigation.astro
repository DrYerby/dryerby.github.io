---
const { currentPath = '/' } = Astro.props;
const links = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
  { href: '/teaching/', label: 'Teaching' },
  { href: '/research/', label: 'Research' },
  { href: '/leadership/', label: 'Leadership & Service' },
  { href: '/media/', label: 'Media & Press' },
  { href: '/cv/', label: 'CV' },
];
---

<nav class="site-nav" aria-label="Primary">
  <ul>
    {links.map((link) => {
      const isCurrent = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
      return (
        <li>
          <a href={link.href} aria-current={isCurrent ? 'page' : undefined}>
            {link.label}
          </a>
        </li>
      );
    })}
  </ul>
</nav>
