---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Curriculum Vitae | Johnathan Yerby, Ph.D.';
const description = 'Current curriculum vitae of Johnathan Yerby, Ph.D., including academic appointments, teaching, research, publications, grants, leadership, and professional service.';
const cvUrl = '/documents/Johnathan-Yerby-CV.pdf';
---

<BaseLayout title={title} description={description} currentPath="/cv/">
  <section class="page-shell">
    <header class="page-shell__header">
      <p class="eyebrow">CV</p>
      <h1>Curriculum Vitae</h1>
      <p class="page-shell__intro">The current curriculum vitae for Johnathan Yerby, Ph.D., includes academic appointments, teaching, research, publications, grants, professional service, leadership, and related professional activity.</p>
      <p class="page-shell__intro"><strong>Updated July 2026</strong></p>
    </header>
    <div class="page-shell__content">
      <p><a class="button-link" href={cvUrl}>Download Current CV</a></p>
      <p><a href={cvUrl}>Open CV in Browser</a></p>
    </div>
  </section>
</BaseLayout>
