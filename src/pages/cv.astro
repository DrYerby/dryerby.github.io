---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'CV';
const description = 'Curriculum vitae information for Johnathan Yerby.';
---

<BaseLayout title={title} description={description} currentPath="/cv/">
  <section class="page-shell">
    <header class="page-shell__header">
      <p class="eyebrow">CV</p>
      <h1>Curriculum Vitae</h1>
      <p class="page-intro">This page will be updated with curriculum vitae details.</p>
    </header>
    <div class="page-shell__content">
      <p>This page will be updated with curriculum vitae details.</p>
    </div>
  </section>
</BaseLayout>
