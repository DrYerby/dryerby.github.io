---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Research';
const description = 'Research interests and scholarship profile for Johnathan Yerby.';
---

<BaseLayout title={title} description={description} currentPath="/research/">
  <section class="page-shell">
    <header class="page-shell__header">
      <p class="eyebrow">Research</p>
      <h1>Research</h1>
      <p class="page-intro">This page will be updated with current research and scholarship information.</p>
    </header>
    <div class="page-shell__content">
      <p>This page will be updated with current research and scholarship information.</p>
    </div>
  </section>
</BaseLayout>
