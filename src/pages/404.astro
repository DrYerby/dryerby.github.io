---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Page not found';
const description = 'The requested page could not be found.';
---

<BaseLayout title={title} description={description} currentPath="/404.html">
  <section class="page-shell">
    <header class="page-shell__header">
      <p class="eyebrow">404</p>
      <h1>Page not found</h1>
      <p class="page-intro">The requested page could not be found. Please return to the homepage and navigate from there.</p>
    </header>
    <div class="page-shell__content">
      <p>The requested page could not be found. Please return to the homepage and navigate from there.</p>
    </div>
  </section>
</BaseLayout>
