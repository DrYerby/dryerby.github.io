---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Independent Cybersecurity Consulting | Johnathan Yerby, Ph.D.';
const description = 'Selective, project-based cybersecurity consulting focused on strategy, failure analysis, investigations, technical interpretation, source-code and systems analysis, business-process improvement, and cybersecurity education including CAE support.';

const consultingJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Independent cybersecurity consulting and expert analysis',
  provider: {
    '@type': 'Person',
    name: 'Johnathan Yerby',
    jobTitle: 'Associate Professor of Computer Science',
    sameAs: [
      'https://www.linkedin.com/in/yerby/',
      'https://scholar.google.com/citations?user=e6s__p0AAAAJ&hl=en',
      'https://orcid.org/0000-0001-8945-855X',
    ],
  },
  areaServed: 'United States',
  description,
};
---

<BaseLayout title={title} description={description} currentPath="/consulting/">
  <section class="page-shell">
    <header class="page-shell__header">
      <p class="eyebrow">Independent Consulting Practice</p>
      <h1>Cybersecurity Consulting, Analysis, and Expert Support</h1>
      <p class="page-shell__intro readable-prose">Dr. Yerby provides independent cybersecurity consulting in selective, higher-value engagements requiring expert judgment, technical interpretation, investigation support, failure analysis, program and process evaluation, and clear communication for legal and executive decision-making. The practice is project-based and advisory in nature, with emphasis on analysis, interpretation, and practical direction rather than routine technical support labor.</p>
    </header>

    <div class="page-shell__content">
      <section class="page-shell__section" aria-labelledby="areas-of-engagement">
        <h2 id="areas-of-engagement">Consulting Position and Engagement Focus</h2>
        <p class="readable-prose">Dr. Yerby helps attorneys, executives, educational institutions, professional organizations, and other decision-makers understand complex cybersecurity and technology matters. Engagements commonly focus on analyzing what happened, identifying why it happened, evaluating contributing technical or organizational failures, assessing the significance of technical findings, and explaining implications to nontechnical audiences.</p>
        <ul class="consulting-areas-list">
          <li>Independent, project-based consulting and expert analysis</li>
          <li>Cybersecurity strategy, failure analysis, and advisory services</li>
          <li>Investigative and evidentiary interpretation support</li>
          <li>Targeted software, systems, and source-code analysis</li>
          <li>Cybersecurity education, CAE consulting, and substantive program-development support</li>
          <li>Business-process improvement tied to cybersecurity, governance, and operational outcomes</li>
        </ul>
      </section>

      <div class="consulting-category-grid">
        <section class="page-shell__section page-shell__section--card consulting-service" aria-labelledby="strategy-failure-advisory">
          <h2 id="strategy-failure-advisory">1. Cybersecurity Strategy, Failure Analysis, and Advisory Services</h2>
          <ul>
            <li>Cybersecurity program assessment</li>
            <li>Governance, risk, and control evaluation</li>
            <li>Analysis of overarching cybersecurity failures and adverse outcomes</li>
            <li>Evaluation of technical, administrative, organizational, and process breakdowns</li>
            <li>Advisory-level security architecture and system-design review</li>
            <li>Cybersecurity policy and procedure assessment</li>
            <li>Risk communication for executives, boards, attorneys, and institutional leaders</li>
            <li>Independent review of cybersecurity findings, reports, recommendations, or competing technical explanations</li>
            <li>Pre-engagement scoping to help clients select appropriate cybersecurity specialists and avoid mismatched or unnecessary services</li>
          </ul>
          <p class="readable-prose">This practice may evaluate configurations, systems, documentation, and technical decisions that contributed to outcomes. It is not marketed as routine installation, configuration, or day-to-day administration work.</p>
        </section>

        <section class="page-shell__section page-shell__section--card consulting-service" aria-labelledby="investigations-digital-evidence-expert-consulting">
          <h2 id="investigations-digital-evidence-expert-consulting">2. Investigations, Digital Evidence, and Expert Consulting</h2>
          <ul>
            <li>Technical assistance with investigations</li>
            <li>Independent review of digital evidence and electronic records</li>
            <li>Targeted forensic examination and targeted deleted-data examination when technically appropriate</li>
            <li>Review and interpretation of forensic findings produced by other specialists</li>
            <li>Validation or critique of technical conclusions</li>
            <li>Timeline reconstruction from logs, metadata, repositories, system records, and documentation</li>
            <li>Identification of evidentiary limitations, unsupported assumptions, and alternative explanations</li>
            <li>Communication of technical findings for attorneys, courts, investigators, executives, boards, and institutional stakeholders</li>
          </ul>
          <p class="readable-prose">Dr. Yerby has assisted with prior investigations and court matters. The practice is not positioned as a full-service forensic laboratory, emergency evidence-collection provider, or high-volume e-discovery processor. Deleted-data recovery feasibility depends on storage technology, preservation conditions, prior use, encryption, and available access. When specialized laboratory capabilities are needed, referrals or coordinated work with qualified providers may be appropriate.</p>
        </section>

        <section class="page-shell__section page-shell__section--card consulting-service" aria-labelledby="source-code-software-technology-analysis">
          <h2 id="source-code-software-technology-analysis">3. Source-Code, Software, and Technology Analysis</h2>
          <ul>
            <li>Targeted source-code review tied to defined questions and scope</li>
            <li>Software-behavior and system-behavior analysis</li>
            <li>Repository and version-history review, including commits, branches, releases, and configuration changes</li>
            <li>Evaluation of whether observed behavior aligns with requirements, representations, policies, or allegations</li>
            <li>Independent review of technical reports concerning software and systems</li>
            <li>Explanation of software findings for legal, executive, academic, and investigative audiences</li>
            <li>Evaluation of system design, information flow, control weaknesses, and process dependencies</li>
          </ul>
          <p class="readable-prose">Source-code and software engagements are targeted and question-driven. The practice does not represent unlimited development capacity, exhaustive review of every platform, guaranteed discovery of every vulnerability, or open-ended review of very large repositories without agreed scope.</p>
        </section>

        <section class="page-shell__section page-shell__section--card consulting-service" aria-labelledby="cybersecurity-education-cae-program-development">
          <h2 id="cybersecurity-education-cae-program-development">4. Cybersecurity Education, CAE, and Program Development</h2>
          <ul>
            <li>Cybersecurity curriculum development and academic-program design</li>
            <li>Program review, evaluation, and structured improvement planning</li>
            <li>NSA CAE in Cyber Defense preparation and CAE knowledge-unit mapping</li>
            <li>CAE evidence identification, preparation, organization, and review</li>
            <li>CAE application and redesignation support, plus continuing alignment support</li>
            <li>Course and curriculum mapping, assessment planning, and documentation development</li>
            <li>Student-learning outcome development and faculty development</li>
            <li>Workforce preparation, competition design, and experiential-learning design</li>
            <li>Grant development and grant-supported cybersecurity education initiatives</li>
            <li>Substantive outsourced project work for colleges, universities, and educational organizations</li>
          </ul>
          <p class="readable-prose">This category includes both strategic advisory work and substantial project execution. No representation is made that any engagement can guarantee CAE designation, accreditation, funding, or agency approval outcomes.</p>
        </section>
      </div>

      <section class="page-shell__section page-shell__section--card" aria-labelledby="business-process-improvement">
        <h2 id="business-process-improvement">Business-Process Improvement</h2>
        <p class="readable-prose">Business-process improvement is a long-standing consulting area within this practice. Engagements are analytical and strategic, focused on how technology-dependent processes, controls, and governance decisions affect operational reliability and cybersecurity outcomes.</p>
        <ul>
          <li>Process mapping and workflow evaluation</li>
          <li>Identification of inefficiencies, control gaps, and weak accountability points</li>
          <li>Evaluation of technology-supported business processes and information flow</li>
          <li>Role and responsibility analysis and documentation review</li>
          <li>Identification of unnecessary complexity, duplication, delay, and process friction</li>
          <li>Improvement of cybersecurity-related and technology-dependent processes</li>
          <li>Alignment of business processes with governance, compliance, and operational objectives</li>
          <li>Development of practical recommendations for executives and process owners</li>
        </ul>
      </section>

      <section class="page-shell__section page-shell__section--card" aria-labelledby="services-not-ordinarily-provided">
        <h2 id="services-not-ordinarily-provided">Services Not Ordinarily Provided</h2>
        <p class="readable-prose">This practice is focused on advisory, analytical, educational, investigative, and expert engagements. It does not ordinarily provide the following services as standalone offerings:</p>
        <ul>
          <li>Consumer technical support, home computer repair, printer troubleshooting, home Wi-Fi support, password or personal account recovery</li>
          <li>Routine software installation, routine firewall configuration, routine network administration, and help-desk services</li>
          <li>Managed IT services, managed security services, website development, or general software development</li>
          <li>Emergency ransomware response, around-the-clock incident response, routine penetration testing, or routine vulnerability scanning</li>
          <li>High-volume forensic acquisition, specialized forensic laboratory procedures, physical media repair, or guaranteed deleted-data recovery</li>
        </ul>
        <p class="readable-prose">When requested work falls outside this practice, Dr. Yerby can help determine the appropriate type of specialist or service provider and may coordinate with qualified providers when that supports the broader engagement.</p>
      </section>

      <section class="page-shell__section consulting-standards" aria-labelledby="scope-and-limitations">
        <h2 id="scope-and-limitations">Scope and Limitations</h2>
        <ol>
          <li>Engagements are project-based and defined by an agreed scope.</li>
          <li>Reviews are limited to the questions, systems, records, evidence, code, documentation, access, time, and procedures included in the engagement.</li>
          <li>No guarantee is made of a particular finding, successful data recovery, identification of every vulnerability, regulatory approval, audit passage, CAE designation, litigation result, or organizational outcome.</li>
          <li>Services are not legal advice.</li>
          <li>Cybersecurity compliance-related work is typically delivered as readiness assessment, alignment review, gap analysis, documentation review, control evaluation, and program improvement.</li>
          <li>When required capabilities fall outside scope, Dr. Yerby may recommend another qualified provider, work alongside another specialist, limit his role to independent review and interpretation, or decline the engagement.</li>
        </ol>
      </section>

      <section class="page-shell__section page-shell__section--card" aria-labelledby="expert-and-legal-matters">
        <h2 id="expert-and-legal-matters">Expert and Legal Matters</h2>
        <p class="readable-prose">Dr. Yerby has provided prior assistance in investigations and court matters through independent technical consultation, case assessment, evaluation of allegations and technical theories, evidentiary analysis, technical-discovery support, review of opposing expert reports, independent reporting, deposition support, and testimony when appropriate.</p>
        <p class="readable-prose">Legal and expert engagements are accepted only after conflict review, preliminary subject-matter evaluation, confirmation that the matter aligns with documented education, training, experience, and expertise, and agreement on scope, schedule, rates, and expected work product. Opinions are independent and are never contingent on producing a requested conclusion.</p>
      </section>

      <section class="page-shell__section" aria-labelledby="professional-inquiries-consulting">
        <h2 id="professional-inquiries-consulting">Professional Inquiries</h2>
        <p class="readable-prose">To evaluate fit and scope, include the following in an initial inquiry:</p>
        <ul>
          <li>Name and organization</li>
          <li>Nature of the requested engagement and the specific question or problem</li>
          <li>Relevant industry, institution, system, or program context</li>
          <li>Anticipated materials and approximate volume of records, evidence, data, or source code</li>
          <li>Desired work product and relevant deadlines</li>
          <li>Whether testimony, a written report, presentation, or on-site work may be required</li>
          <li>For legal matters: law firm, represented party, opposing parties, case caption, jurisdiction, and anticipated litigation schedule</li>
        </ul>
        <p class="readable-prose">Please do not send confidential, privileged, protected, or irreplaceable materials until conflicts, scope, and engagement terms have been reviewed and confirmed.</p>
        <p class="readable-prose">Independent consulting services are provided by Dr. Johnathan Yerby in his individual professional capacity and not on behalf of Mercer University. Academic titles and institutional affiliations are provided for biographical identification only and do not imply institutional sponsorship, endorsement, responsibility, or participation.</p>
        <p class="readable-prose">Depending on the timing, anticipated effort, and nature of the engagement, outside professional work may be subject to applicable university disclosure or approval requirements.</p>
        <div class="consulting-contact-links" aria-label="Professional links">
          <a class="button-link" href="mailto:yerby_jm@mercer.edu">Submit an Inquiry</a>
          <a class="button-link button-link--secondary" href="/documents/Johnathan_Yerby-CV.pdf">View Current CV</a>
        </div>
      </section>
    </div>
  </section>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(consultingJsonLd)} />
</BaseLayout>
