---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Cybersecurity Consulting and Expert Analysis | Johnathan Yerby, Ph.D.';
const description = 'Selective cybersecurity consulting and expert analysis involving failure analysis, investigations, source code, digital evidence, security controls, business processes, academic programs, and expert support.';

const consultingJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Cybersecurity consulting and expert analysis',
  provider: {
    '@type': 'Person',
    name: 'Johnathan Yerby',
    jobTitle: 'Associate Professor of Computer Science',
    sameAs: [
      'https://www.linkedin.com/in/yerby/',
      'https://scholar.google.com/citations?user=e6s__p0AAAAJ&hl=en',
      'https://orcid.org/0000-0001-8945-855X',
    ],
  },
  areaServed: 'United States',
  description,
};
---

<BaseLayout title={title} description={description} currentPath="/consulting/">
  <section class="page-shell">
    <header class="page-shell__header">
      <p class="eyebrow">Independent Consulting Practice</p>
      <h1>Cybersecurity Consulting, Analysis, and Expert Support</h1>
      <p class="page-shell__intro readable-prose">Dr. Yerby provides independent cybersecurity consulting, expert analysis, and advisory support for complex technical, organizational, academic, and legal matters. His work focuses on interpreting evidence, identifying failures in systems and processes, evaluating cybersecurity practices, and communicating defensible findings to decision-makers.</p>
      <p class="page-shell__intro readable-prose">Consulting engagements are selective, project-based, and focused on matters requiring experienced interpretation, independent judgment, and communication across technical and nontechnical audiences.</p>
      <p class="page-shell__intro readable-prose">Engagements may support attorneys, executives, educational institutions, government organizations, investigators, and other professional decision-makers.</p>
    </header>

    <div class="page-shell__content">
      <div class="consulting-focus-grid">
        <section class="page-shell__section consulting-focus" aria-labelledby="strategy-failure-advisory">
          <h2 id="strategy-failure-advisory">Cybersecurity Strategy, Failure Analysis, and Advisory Services</h2>
          <p>Independent advisory work focused on understanding cybersecurity weaknesses, organizational failures, governance issues, and technology-dependent business processes.</p>
          <ul>
            <li>Cybersecurity program and risk assessment</li>
            <li>Governance, security-control, and policy evaluation</li>
            <li>Analysis of technical, administrative, organizational, and process failures</li>
            <li>Review of cybersecurity findings, reports, recommendations, and competing technical explanations</li>
            <li>Evaluation of security architecture, system design, and control dependencies</li>
            <li>Business-process analysis involving technology, accountability, governance, and operational reliability</li>
            <li>Communication of findings to executives, boards, attorneys, administrators, and institutional leaders</li>
            <li>Pre-engagement scoping to help determine the appropriate type of expert, consultant, laboratory, or service provider</li>
          </ul>
          <p>This work is advisory and analytical. It is not marketed as routine technical support, installation, configuration, or day-to-day systems administration.</p>
        </section>

        <section class="page-shell__section consulting-focus" aria-labelledby="investigations-digital-evidence-expert-support">
          <h2 id="investigations-digital-evidence-expert-support">Investigations, Digital Evidence, and Expert Support</h2>
          <p>Technical analysis and expert support for investigations, disputes, and matters involving digital evidence, electronic records, or competing technical interpretations.</p>
          <ul>
            <li>Technical assistance with investigations</li>
            <li>Independent review of digital evidence and electronic records</li>
            <li>Interpretation of forensic findings produced by other specialists</li>
            <li>Review and critique of technical conclusions, assumptions, and alternative explanations</li>
            <li>Targeted forensic examination when appropriate to the available tools, evidence, and agreed scope</li>
            <li>Identification of evidentiary limitations, unsupported assumptions, and documentation gaps</li>
            <li>Written reports, deposition support, and courtroom explanation when relevant to an accepted engagement</li>
            <li>Communication of complex findings to legal, investigative, executive, and professional audiences</li>
          </ul>
          <p>Dr. Yerby has assisted with investigations and court matters through independent technical consultation, case assessment, evidentiary analysis, technical-discovery support, review of opposing expert reports, independent reporting, deposition support, and testimony when appropriate. Matters that require specialized forensic laboratory capabilities, emergency evidence collection, or high-volume recovery may require another provider or coordinated work with qualified specialists.</p>
        </section>

        <section class="page-shell__section consulting-focus" aria-labelledby="software-source-code-technology-analysis">
          <h2 id="software-source-code-technology-analysis">Software, Source Code, and Technology Analysis</h2>
          <p>Targeted technical analysis of software, source code, systems, records, and documented technology behavior.</p>
          <ul>
            <li>Source-code review tied to defined questions and scope</li>
            <li>Software-behavior and system-behavior analysis</li>
            <li>Repository and version-history review, including commits, branches, releases, and configuration changes</li>
            <li>Evaluation of whether observed behavior aligns with documented requirements, representations, policies, or allegations</li>
            <li>Review of technical reports concerning software and systems</li>
            <li>Analysis of system design, information flow, control weaknesses, and process dependencies</li>
            <li>Explanation of findings for legal, executive, academic, investigative, and professional audiences</li>
          </ul>
          <p>Source-code and software engagements are targeted and question-driven. The practice does not represent unlimited development capacity, exhaustive review of every platform, guaranteed discovery of every vulnerability, or open-ended review of very large repositories without an agreed scope.</p>
        </section>

        <section class="page-shell__section consulting-focus" aria-labelledby="cae-program-development">
          <h2 id="cae-program-development">Cybersecurity Education, CAE, and Program Development</h2>
          <p>Strategic and substantive consulting for colleges, universities, schools, educational organizations, and workforce-development initiatives.</p>
          <ul>
            <li>Cybersecurity curriculum development and academic-program design</li>
            <li>Program review, evaluation, and structured improvement planning</li>
            <li>NSA Center of Academic Excellence in Cyber Defense preparation and knowledge-unit mapping</li>
            <li>CAE evidence identification, preparation, organization, and review</li>
            <li>CAE application, redesignation, and continuing-alignment support</li>
            <li>Course and curriculum mapping, assessment planning, and documentation development</li>
            <li>Student-learning outcome development and faculty development</li>
            <li>Workforce-preparation, competition, and experiential-learning design</li>
            <li>Grant development and grant-supported cybersecurity education initiatives</li>
            <li>Substantive outsourced project work for educational institutions</li>
          </ul>
          <p>This category may include strategic advisory work, detailed project execution, or both. No representation is made that an engagement can guarantee accreditation, funding, designation, approval, or agency outcomes.</p>
        </section>
      </div>

      <section class="page-shell__section consulting-compact" aria-labelledby="engagement-approach">
        <h2 id="engagement-approach">Engagement Approach</h2>
        <p>Engagements are project-based and defined by an agreed scope. Dr. Yerby accepts work only when the questions presented fall within documented areas of expertise and can be addressed through available evidence, records, systems, and methods.</p>
        <p>Reviews are limited to the materials, access, time, and procedures included in the engagement. No particular finding, recovery result, regulatory approval, audit outcome, litigation result, designation decision, or organizational outcome is guaranteed.</p>
        <p>When specialized laboratory services, emergency incident response, managed IT services, routine technical support, or capabilities outside the agreed scope are needed, Dr. Yerby may recommend or coordinate with other qualified providers.</p>
        <p>Services are not legal advice or legal representation.</p>
      </section>

      <section class="page-shell__section" aria-labelledby="professional-inquiries-consulting">
        <h2 id="professional-inquiries-consulting">Professional Inquiries</h2>
        <p class="readable-prose">To evaluate fit and scope, an initial inquiry should briefly include:</p>
        <ul>
          <li>Name and organization</li>
          <li>Nature of the matter and the primary question to be addressed</li>
          <li>Relevant industry, institution, system, or program context</li>
          <li>Expected records, evidence, data, documentation, or source code</li>
          <li>Anticipated work product and timeline</li>
          <li>Whether testimony, a written report, presentation, or on-site work may be required</li>
          <li>For legal matters, the law firm, represented party, jurisdiction, case caption, and anticipated litigation schedule</li>
        </ul>
        <p class="readable-prose">Please do not send confidential, privileged, protected, or irreplaceable materials until conflicts, scope, and engagement terms have been reviewed and confirmed.</p>
        <p class="readable-prose">Independent consulting services are provided by Dr. Johnathan Yerby in his individual professional capacity and not on behalf of Mercer University. Academic titles and institutional affiliations are provided for professional identification only and do not imply institutional sponsorship, endorsement, responsibility, or participation.</p>
        <p class="readable-prose">Depending on the timing, anticipated effort, and nature of the engagement, outside professional work may be subject to applicable university disclosure or approval requirements.</p>
        <div class="consulting-contact-links" aria-label="Professional links">
           <a class="button-link" href="mailto:yerby_jm@mercer.edu?subject=Consulting%20Engagement%20Inquiry">Email Dr. Yerby</a>
          <a class="button-link button-link--secondary" href="/documents/Johnathan_Yerby-CV.pdf">View Current CV →</a>
        </div>
      </section>
    </div>
  </section>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(consultingJsonLd)} />
</BaseLayout>
