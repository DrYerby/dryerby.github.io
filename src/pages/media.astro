---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Media & Press';
const description = 'Media and press information for Johnathan Yerby.';
---

<BaseLayout title={title} description={description} currentPath="/media/">
  <section class="page-shell">
    <header class="page-shell__header">
      <p class="eyebrow">Media & Press</p>
      <h1>Media & Press</h1>
      <p class="page-intro">This page will be updated with media and press references.</p>
    </header>
    <div class="page-shell__content">
      <p>This page will be updated with media and press references.</p>
    </div>
  </section>
</BaseLayout>
