---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'About Johnathan Yerby';
const description = 'Professional biography, academic background, and areas of expertise for Johnathan Yerby, Ph.D., Associate Professor of Computer Science at Mercer University.';
---

<BaseLayout title={title} description={description} currentPath="/about/">
  <section class="page-shell">
    <header class="page-shell__header">
      <p class="eyebrow">About</p>
      <h1>About Johnathan Yerby</h1>
      <p class="page-intro">Dr. Yerby is a cybersecurity educator, researcher, and academic leader whose professional background spans higher education, cybersecurity, information technology, systems administration, project management, consulting, and regulated business environments.</p>
    </header>
    <div class="page-shell__content">
      <p>At Mercer University, he teaches and develops courses across undergraduate and graduate cybersecurity pathways. He directs the Cybersecurity Program and the Center for Cyber Outreach, Research, and Education, serves as Mercer’s CAE institutional point of contact, and he mentors students through research, internships, certifications, competitions, and graduate thesis work.</p>
      <p>Before joining Mercer in 2021, he served at Middle Georgia State University, including as Department Chair and tenured Associate Professor of Information Technology. His work there included curriculum and program leadership, faculty and staff supervision, applied networking and digital-forensics laboratories, workforce partnerships, advising, and cybersecurity education.</p>
      <h2>Academic Background</h2>
      <ul>
        <li>Ph.D. in Instructional Technology, Georgia State University, 2017</li>
        <li>Master of Business Administration, Georgia College &amp; State University, 2011</li>
        <li>Master of Management Information Systems, Georgia College &amp; State University, 2009</li>
        <li>Bachelor of Science in Information Technology, Macon State College, 2006</li>
      </ul>
      <h2>Professional Interests</h2>
      <ul>
        <li>Cybersecurity education and workforce development</li>
        <li>Privacy, surveillance, and technology governance</li>
        <li>Digital forensics and cyber experimentation</li>
        <li>Governance, risk, compliance, law, and ethics</li>
        <li>Curriculum and academic-program development</li>
        <li>Student research and professional mentoring</li>
        <li>Public cybersecurity education and outreach</li>
      </ul>
      <h2>Approach</h2>
      <p>Across teaching, scholarship, and service, his work emphasizes practical learning, clear communication, professional judgment, and the responsible use of technology. He is particularly interested in work that connects academic programs with student opportunity, public understanding, and professional practice.</p>
    </div>
  </section>
</BaseLayout>
