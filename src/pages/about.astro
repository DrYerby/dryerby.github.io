---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'About';
const description = 'Academic and professional profile overview for Johnathan Yerby.';
---

<BaseLayout title={title} description={description} currentPath="/about/">
  <section class="page-shell">
    <header class="page-shell__header">
      <p class="eyebrow">About</p>
      <h1>About</h1>
      <p class="page-intro">This page will be updated with a concise academic and professional overview.</p>
    </header>
    <div class="page-shell__content">
      <p>This page will be updated with a concise academic and professional overview.</p>
    </div>
  </section>
</BaseLayout>
