---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';

const title = 'Johnathan Yerby, Ph.D.';
const description = 'Professional website of Johnathan Yerby, Ph.D., Associate Professor of Computer Science and cybersecurity program director at Mercer University.';
---

<BaseLayout title={title} description={description} currentPath="/">
  <div class="homepage-shell">
    <Hero
      title="Johnathan Yerby, Ph.D."
      eyebrow="Cybersecurity Education • Research • Leadership"
      roles={[
        'Associate Professor of Computer Science',
        'Director, Cybersecurity Program',
        'Director, Center for Cyber Outreach, Research, and Education',
        'Mercer University',
      ]}
      intro="Dr. Yerby's work is grounded in lifelong learning through continuing to learn, teaching and mentoring others, and helping students build useful knowledge and skills for their professional and personal lives. His academic interests include cybersecurity education, digital privacy and surveillance, cyber risk and governance, digital forensics, and professional preparation."
      actions={[
        { href: '/cv/', label: 'View CV' },
        { href: '/research/', label: 'Research & Scholarship', secondary: true },
        { href: '/media/', label: 'Media & Press', secondary: true },
      ]}
    />
    <section class="homepage-section">
      <SectionHeading title="Areas of Focus" />
      <ul class="focus-list">
        <li>Cybersecurity education and workforce development</li>
        <li>Digital privacy, surveillance, and public-facing cyber risk</li>
        <li>Cybersecurity governance, risk, law, ethics, and compliance</li>
        <li>Digital forensics and applied cybersecurity</li>
        <li>Academic program and curriculum leadership</li>
      </ul>
    </section>
    <section class="homepage-section">
      <SectionHeading title="Selected Work" />
      <div class="page-shell__content">
        <h3>Cybersecurity Education and Program Leadership</h3>
        <p>Directs Mercer’s cybersecurity program and supports curriculum, assessment, advising, faculty coordination, student development, and continuing alignment with national cybersecurity education standards.</p>
        <h3>Research and Student Mentoring</h3>
        <p>Research interests include cybersecurity education, privacy, surveillance, governance, digital forensics, and public-facing cyber risk, with an emphasis on involving undergraduate and graduate students in scholarly work.</p>
        <h3>Outreach and Professional Engagement</h3>
        <p>Through CORE and related activities, supports cybersecurity outreach, public education, student opportunities, and collaboration with educators, employers, government organizations, and community audiences.</p>
      </div>
    </section>
    <section class="homepage-section">
      <SectionHeading title="Explore the Site" subtitle="Learn more about teaching, research, academic leadership, public engagement, and current professional activities." />
      <div class="hero__actions">
        <a class="button-link" href="/about/">About</a>
        <a class="button-link button-link--secondary" href="/teaching/">Teaching</a>
        <a class="button-link button-link--secondary" href="/research/">Research</a>
        <a class="button-link button-link--secondary" href="/leadership/">Leadership &amp; Service</a>
      </div>
    </section>
  </div>
</BaseLayout>
